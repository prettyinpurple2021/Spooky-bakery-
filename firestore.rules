rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { 
      allow read, write: if false; 
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    function isValidRecipe(data) {
      return data.keys().hasAll(['title', 'prep', 'cook', 'yield', 'category', 'ingredients', 'directions', 'favorite', 'ownerId', 'createdAt', 'updatedAt'])
        && (data.keys().size() == 11 || (data.keys().size() == 12 && 'imageUrl' in data))
        && data.title is string && data.title.size() <= 200
        && data.prep is string && data.prep.size() <= 100
        && data.cook is string && data.cook.size() <= 100
        && data.yield is string && data.yield.size() <= 100
        && data.category is string && data.category in ['Cake', 'Dessert', 'Breakfast', 'Other']
        && data.ingredients is list && data.ingredients.size() <= 50
        && (data.ingredients.size() == 0 || data.ingredients[0] is string)
        && data.directions is list && data.directions.size() <= 50
        && (data.directions.size() == 0 || data.directions[0] is string)
        && data.favorite is bool
        && data.ownerId == request.auth.uid
        && (!('imageUrl' in data) || data.imageUrl is string);
    }

    match /recipes/{recipeId} {
      allow read: if isSignedIn() && existing().ownerId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(recipeId)
        && isValidRecipe(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;

      allow update: if isSignedIn()
        && isValidId(recipeId)
        && isValidRecipe(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && incoming().ownerId == existing().ownerId;
        
      allow delete: if isSignedIn()
        && existing().ownerId == request.auth.uid;
    }
  }
}
